        private void AddCurrentBarcode()
        {
            var code = newStringTextBox.Text;
            if (string.IsNullOrEmpty(code))
                return;

            _items.Add(new BarcodeItem
            {
                Code = code,
                TypeName = Barcode.GetTypeName(code)
            });

            newStringTextBox.Clear();
        }

        private void itemsListView_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.Key != Key.Delete)
                return;

            if (itemsListView.SelectedItem is BarcodeItem selected)
            {
                _items.Remove(selected);
            }
        }

        private void newStringTextBox_TextChanged(object sender, TextChangedEventArgs e)
        {
            var rawText = newStringTextBox.Text;

            if (string.IsNullOrEmpty(rawText))
            {
                SetCodeTypeLabel(null);
                previewImage.Source = null;
                return;
            }

            // Strip whitespace/newlines for barcode type detection
            var trimmed = rawText.Replace("\r", "").Replace("\n", "").Trim();
            var type = string.IsNullOrEmpty(trimmed) ? "Text" : Barcode.GetTypeName(trimmed);

            SetCodeTypeLabel(type);
            UpdatePreview(rawText);
        }

        private void itemsListView_SelectionChanged(object sender, SelectionChangedEventArgs e)
        {
            if (itemsListView.SelectedItem is BarcodeItem selected)
            {
                SetCodeTypeLabel(selected.TypeName);
                UpdatePreview(selected.Code);
            }
        }

        private void SetCodeTypeLabel(string? type)
        {
            if (type == null)
            {
                newCodeTypeLabel.Text = "Type";
                newCodeTypeLabel.Foreground = (System.Windows.Media.Brush)FindResource("TextFillColorDisabledBrush");
                newCodeTypeLabel.FontStyle = FontStyles.Italic;
            }
            else
            {
                newCodeTypeLabel.Text = type;
                newCodeTypeLabel.Foreground = (System.Windows.Media.Brush)FindResource("TextFillColorPrimaryBrush");
                newCodeTypeLabel.FontStyle = FontStyles.Normal;
            }
        }

        private void previewTypeChanged(object sender, RoutedEventArgs e)
        {
            var text = newStringTextBox?.Text;
            if (!string.IsNullOrEmpty(text))
                UpdatePreview(text);
        }

        private void printButton_Click(object sender, RoutedEventArgs e)
        {
            if (previewImage.Source == null)
            {
                MessageBox.Show("No barcode to print. Add a code first.", "Print", MessageBoxButton.OK, MessageBoxImage.Information);
                return;
            }

            var printDialog = new System.Windows.Controls.PrintDialog();
            if (printDialog.ShowDialog() == true)
            {
                var visual = new System.Windows.Controls.Image
                {
                    Source = previewImage.Source,
                    Stretch = System.Windows.Media.Stretch.Uniform
                };

                var area = printDialog.PrintableAreaWidth < printDialog.PrintableAreaHeight
                    ? printDialog.PrintableAreaWidth
                    : printDialog.PrintableAreaHeight;

                visual.Measure(new System.Windows.Size(printDialog.PrintableAreaWidth, printDialog.PrintableAreaHeight));
                visual.Arrange(new System.Windows.Rect(0, 0, printDialog.PrintableAreaWidth, printDialog.PrintableAreaHeight));

                printDialog.PrintVisual(visual, "Barcode Print");
            }
        }

        private void UpdatePreview(string text)
        {
            try
            {
                if (qrCodeRadio?.IsChecked == true)
                {
                    previewImage.Source = GenerateQrCode(text);
                }
                else
                {
                    previewImage.Source = GenerateBarcode(text);
                }
            }
            catch
            {
                previewImage.Source = null;
            }
        }

        private static BitmapSource GenerateQrCode(string text)
        {
            using var qrGenerator = new QRCodeGenerator();
            using var qrCodeData = qrGenerator.CreateQrCode(text, QRCodeGenerator.ECCLevel.H);
            using var qrCode = new QRCode(qrCodeData);

            // Try to load QrIcon from Branding folder
            var qrIconPath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Branding", "QrIcon.png");
            if (File.Exists(qrIconPath))
            {
                using var icon = new Bitmap(qrIconPath);
                using var bitmap = qrCode.GetGraphic(10, System.Drawing.Color.Black, System.Drawing.Color.White, icon, 15, 6, true);
                return BitmapToSource(bitmap);
            }
            else
            {
                using var bitmap = qrCode.GetGraphic(10);
                return BitmapToSource(bitmap);
            }
        }

        private static BitmapSource GenerateBarcode(string text)
        {
            // Simple Code128-style barcode renderer
            int barWidth = 2;
            int height = 80;
            int padding = 20;

            // Encode each character as a set of bars
            var bars = new System.Collections.Generic.List<bool>();
            // Start pattern
            bars.AddRange([true, true, false, true, false]);
            foreach (char c in text)
            {
                // Simple encoding: convert char to 8-bit binary, render as bars
                for (int bit = 7; bit >= 0; bit--)
                {
                    bars.Add(((c >> bit) & 1) == 1);
                }
                bars.Add(false); // separator
            }
            // Stop pattern
            bars.AddRange([true, true, false, true, true]);

            int totalWidth = (bars.Count * barWidth) + (padding * 2);
            int totalHeight = height + (padding * 2) + 20; // extra for text

            using var bitmap = new Bitmap(totalWidth, totalHeight);
            using var g = Graphics.FromImage(bitmap);
            g.Clear(Color.White);

            for (int i = 0; i < bars.Count; i++)
            {
                if (bars[i])
                {
                    g.FillRectangle(Brushes.Black, padding + (i * barWidth), padding, barWidth, height);
                }
            }

            // Draw text below
            using var font = new Font("Consolas", 10);
            var displayText = text.Length > 40 ? text[..40] + "..." : text;
            g.DrawString(displayText, font, Brushes.Black, padding, padding + height + 2);

            return BitmapToSource(bitmap);
        }

        private static BitmapSource BitmapToSource(Bitmap bitmap)
        {
            using var memory = new MemoryStream();
            bitmap.Save(memory, ImageFormat.Png);
            memory.Position = 0;

            var bitmapImage = new BitmapImage();
            bitmapImage.BeginInit();
            bitmapImage.StreamSource = memory;
            bitmapImage.CacheOption = BitmapCacheOption.OnLoad;
            bitmapImage.EndInit();
            bitmapImage.Freeze();
            return bitmapImage;
        }

        public string? GetNextCode()
        {
            if (_items.Count == 0)
                return null;

            if (_currentIndex >= _items.Count)
                _currentIndex = 0;

            var code = _items[_currentIndex].Code;
            _currentIndex = (_currentIndex + 1) % _items.Count;

            itemsListView.SelectedIndex = _currentIndex;

            return code;
        }
    }
