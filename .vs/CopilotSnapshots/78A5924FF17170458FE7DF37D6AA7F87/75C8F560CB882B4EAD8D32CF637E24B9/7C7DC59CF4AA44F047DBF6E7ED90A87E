<Window x:Class="App.Bs.Barcode.Wpf.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:App.Bs.Barcode.Wpf.Ui"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Barcode Simulator" Height="700" Width="520"
        WindowStyle="None" AllowsTransparency="False" ResizeMode="CanResizeWithGrip"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" GlassFrameThickness="0" ResizeBorderThickness="6"
                      CornerRadius="8"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar with Tabs inline -->
        <Grid Grid.Row="0" Background="{ui:ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App Icon -->
            <Image Grid.Column="0" Source="img/bs.png" Width="20" Height="20" Margin="10,0,6,0"
                   RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>

            <!-- Tab Headers inline in title bar -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                <RadioButton x:Name="tabSimulator" GroupName="Tabs" IsChecked="True"
                             Click="Tab_Click" Tag="0" Cursor="Arrow"
                             Style="{StaticResource TitleBarTabStyle}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="BarcodeScanner24" Margin="0,0,4,0" FontSize="14"/>
                        <TextBlock Text="Simulator" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="tabSettings" GroupName="Tabs"
                             Click="Tab_Click" Tag="1" Cursor="Arrow"
                             Style="{StaticResource TitleBarTabStyle}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Settings24" Margin="0,0,4,0" FontSize="14"/>
                        <TextBlock Text="Settings" VerticalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>

            <!-- Window Buttons -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="minimizeButton" Click="MinimizeButton_Click" ToolTip="Minimize"
                        Width="46" Height="36" BorderThickness="0" Background="Transparent"
                        Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" FontFamily="Segoe MDL2 Assets"
                        Content="&#xE921;" FontSize="10" Cursor="Arrow"/>
                <Button x:Name="maximizeButton" Click="MaximizeButton_Click" ToolTip="Maximize"
                        Width="46" Height="36" BorderThickness="0" Background="Transparent"
                        Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" FontFamily="Segoe MDL2 Assets"
                        Content="&#xE922;" FontSize="10" Cursor="Arrow"/>
                <Button x:Name="closeButton" Click="CloseButton_Click" ToolTip="Close"
                        Width="46" Height="36" BorderThickness="0" Background="Transparent"
                        Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" FontFamily="Segoe MDL2 Assets"
                        Content="&#xE8BB;" FontSize="10" Cursor="Arrow"/>
            </StackPanel>
        </Grid>

        <!-- Content area - switch pages -->
        <Grid Grid.Row="1">
            <local:BarcodeSimulatorControl x:Name="simulatorPage"/>
            <local:SettingsControl x:Name="settingsPage" Visibility="Collapsed"/>
        </Grid>

        <!-- Resize Grip -->
        <ResizeGrip Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    WindowChrome.IsHitTestVisibleInChrome="True" Cursor="SizeNWSE"/>
    </Grid>
</Window>
