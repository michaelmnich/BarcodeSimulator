using System;
using System.Diagnostics;
using System.IO;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Media.Imaging;
using UserControl = System.Windows.Controls.UserControl;

namespace App.Bs.Barcode.Wpf.Ui
{
    public partial class SettingsControl : UserControl
    {
        private readonly string _brandingFolder;

        public SettingsControl()
        {
            InitializeComponent();

            var appDir = AppDomain.CurrentDomain.BaseDirectory;
            _brandingFolder = Path.Combine(appDir, "Branding");

            Loaded += SettingsControl_Loaded;
        }

        private void SettingsControl_Loaded(object sender, RoutedEventArgs e)
        {
            // Detect current theme
            var currentTheme = GetCurrentTheme();
            darkThemeRadio.IsChecked = currentTheme == "Dark";
            lightThemeRadio.IsChecked = currentTheme == "Light";

            LoadBrandingImages();
        }

        private void themeRadio_Checked(object sender, RoutedEventArgs e)
        {
            if (!IsLoaded) return;

            var theme = darkThemeRadio.IsChecked == true ? "Dark" : "Light";
            ApplyTheme(theme);
        }

        private static string GetCurrentTheme()
        {
            var resources = System.Windows.Application.Current.Resources;
            if (resources.MergedDictionaries.Count > 0)
            {
                var first = resources.MergedDictionaries[0];
                var source = first.Source?.ToString() ?? "";
                if (source.Contains("Light", StringComparison.OrdinalIgnoreCase))
                    return "Light";
            }
            return "Dark";
        }

        private static void ApplyTheme(string theme)
        {
            var resources = System.Windows.Application.Current.Resources;
            // Find and replace the ThemesDictionary
            for (int i = 0; i < resources.MergedDictionaries.Count; i++)
            {
                var dict = resources.MergedDictionaries[i];
                var source = dict.Source?.ToString() ?? "";
                if (source.Contains("Wpf.Ui") && source.Contains("Theme"))
                {
                    var newUri = source.Contains("Light")
                        ? source.Replace("Light", theme)
                        : source.Replace("Dark", theme);
                    resources.MergedDictionaries[i] = new ResourceDictionary { Source = new Uri(newUri) };
                    Debug.WriteLine($"[Theme] Switched to {theme}");
                    return;
                }
            }

            // Fallback: try via Wpf.Ui API
            try
            {
                var wpfUiTheme = theme == "Dark"
                    ? global::Wpf.Ui.Appearance.ApplicationTheme.Dark
                    : global::Wpf.Ui.Appearance.ApplicationTheme.Light;
                global::Wpf.Ui.Appearance.ApplicationThemeManager.Apply(wpfUiTheme);
                Debug.WriteLine($"[Theme] Applied via WPF-UI API: {theme}");
            }
            catch (Exception ex)
            {
                Debug.WriteLine($"[Theme] Failed to apply: {ex.Message}");
            }
        }

        private void LoadBrandingImages()
        {
            LoadImage(logoDarkImage, logoDarkPath, "LogoDark.png");
            LoadImage(logoLightImage, logoLightPath, "LogoLight.png");
            LoadImage(qrIconImage, qrIconPath, "QrIcon.png");
        }

        private void LoadImage(System.Windows.Controls.Image imageControl, System.Windows.Controls.TextBlock pathLabel, string filename)
        {
            var filePath = Path.Combine(_brandingFolder, filename);
            pathLabel.Text = filePath;

            if (File.Exists(filePath))
            {
                try
                {
                    var bitmap = new BitmapImage();
                    bitmap.BeginInit();
                    bitmap.UriSource = new Uri(filePath, UriKind.Absolute);
                    bitmap.CacheOption = BitmapCacheOption.OnLoad;
                    bitmap.EndInit();
                    bitmap.Freeze();
                    imageControl.Source = bitmap;
                }
                catch (Exception ex)
                {
                    Debug.WriteLine($"[Branding] Failed to load {filename}: {ex.Message}");
                    pathLabel.Text = $"{filePath} (error: {ex.Message})";
                }
            }
            else
            {
                pathLabel.Text = $"{filePath} (not found)";
            }
        }
    }
}
