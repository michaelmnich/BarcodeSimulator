<Window x:Class="App.Bs.Barcode.Wpf.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:App.Bs.Barcode.Wpf.Ui"
        mc:Ignorable="d"
        Title="Barcode Simulator" Height="700" Width="550"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <TabControl>
        <TabItem Header="Simulator">
            <local:BarcodeSimulatorControl/>
        </TabItem>
        <TabItem Header="Settings">
            <local:SettingsControl/>
        </TabItem>
    </TabControl>
</Window>
