<UserControl x:Class="App.Bs.Barcode.Wpf.Ui.BarcodeSimulatorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:tt="clr-namespace:App.Bs.Barcode.Wpf.Ui"
			 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
			 d:DesignHeight="700" d:DesignWidth="520" d:Background="AliceBlue">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="200"/>
		</Grid.RowDefinitions>

		<!-- Configuration -->
		<GroupBox Padding="8,6" Margin="0,0,0,6">
			<GroupBox.Header>
				<StackPanel Orientation="Horizontal">
					<ui:SymbolIcon Symbol="Options24" Margin="0,0,6,0"/>
					<TextBlock Text="Configuration" VerticalAlignment="Center"/>
				</StackPanel>
			</GroupBox.Header>
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<!-- Hotkey -->
				<TextBlock Grid.Row="0" Grid.Column="0" Text="Hotkey:" VerticalAlignment="Center" Margin="0,2"
						   ToolTip="{x:Static tt:ToolTips.Hotkey}"/>
				<Grid Grid.Row="0" Grid.Column="1" Margin="8,2,0,2"
					  ToolTip="{x:Static tt:ToolTips.Hotkey}">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="62"/>
                        <ColumnDefinition Width="62"/>
                        <ColumnDefinition Width="68"/>
                        <ColumnDefinition Width="64"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<CheckBox x:Name="ctrlCheckBox" Grid.Column="0" Content="Ctrl" VerticalAlignment="Center" IsChecked="True" Margin="0,0,4,0"/>
					<CheckBox x:Name="altCheckBox" Grid.Column="1" Content="Alt" VerticalAlignment="Center" Margin="0,0,4,0"/>
					<CheckBox x:Name="shiftCheckBox" Grid.Column="2" Content="Shift" VerticalAlignment="Center" Margin="0,0,4,0"/>
					<CheckBox x:Name="winCheckBox" Grid.Column="3" Content="Win" VerticalAlignment="Center" Margin="0,0,4,0"/>
					<TextBlock Grid.Column="4" Text="+" VerticalAlignment="Center" Margin="0,0,4,0"/>
					<TextBox x:Name="hotkeyKeyTextBox" Grid.Column="5" Width="50" VerticalAlignment="Center" Text="\"
							 MaxLength="10" Margin="0,0,4,0" ToolTip="Type the key, e.g. F, D, F1, \"/>
					<Button Grid.Column="6" Content="Register" Padding="6,1" VerticalAlignment="Center"
							Click="registerHotkeyButton_Click" ToolTip="Click to register or re-register the hotkey."/>
				</Grid>

				<!-- Delay -->
				<TextBlock Grid.Row="1" Grid.Column="0" Text="Delay (ms):" VerticalAlignment="Center" Margin="0,2"
						   ToolTip="{x:Static tt:ToolTips.Delay}"/>
				<TextBox x:Name="delayTextBox" Grid.Row="1" Grid.Column="1" Text="50" Margin="8,2,0,2"
						 ToolTip="{x:Static tt:ToolTips.Delay}"/>

				<!-- Ends With -->
				<TextBlock Grid.Row="2" Grid.Column="0" Text="Ends with:" VerticalAlignment="Center" Margin="0,2"
						   ToolTip="{x:Static tt:ToolTips.EndsWith}"/>
				<ComboBox x:Name="endsWithComboBox" Grid.Row="2" Grid.Column="1" Margin="8,2,0,2"
						  ToolTip="{x:Static tt:ToolTips.EndsWith}"/>
			</Grid>
		</GroupBox>

		<!-- Items -->
		<GroupBox Grid.Row="1" Padding="8,6" Margin="0,0,0,6">
			<GroupBox.Header>
				<StackPanel Orientation="Horizontal">
					<ui:SymbolIcon Symbol="List24" Margin="0,0,6,0"/>
					<TextBlock Text="Items" VerticalAlignment="Center"/>
				</StackPanel>
			</GroupBox.Header>
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- Items List -->
				<ui:ListView x:Name="itemsListView" Grid.Row="0" Margin="5"
						  KeyDown="itemsListView_KeyDown"
						  MinHeight="100"
						  ToolTip="{x:Static tt:ToolTips.ItemsList}">
					<ui:ListView.View>
						<GridView>
							<GridViewColumn Header="Code" DisplayMemberBinding="{Binding Code}" Width="300"/>
							<GridViewColumn Header="Type" DisplayMemberBinding="{Binding TypeName}" Width="100"/>
						</GridView>
					</ui:ListView.View>
				</ui:ListView>

				<!-- New String Entry -->
				<Grid Grid.Row="1">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<TextBox x:Name="newStringTextBox" Grid.Column="0" Margin="5"
							 MinHeight="60" MaxHeight="120"
							 AcceptsReturn="True" AcceptsTab="True"
							 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
							 TextWrapping="Wrap"
							 FontFamily="Consolas" FontSize="12"
							 TextChanged="newStringTextBox_TextChanged"
							 ToolTip="{x:Static tt:ToolTips.NewString}"/>
					<Button Grid.Column="1" Content="Add" Padding="10,2" Click="addButton_Click" Margin="5"
							VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
					<TextBlock x:Name="newCodeTypeLabel" Grid.Column="2" VerticalAlignment="Center" MinWidth="60" Margin="8,0,0,0"/>
				</Grid>
			</Grid>
		</GroupBox>

		<!-- Preview -->
		<GroupBox Grid.Row="2" Padding="8,6">
			<GroupBox.Header>
				<StackPanel Orientation="Horizontal">
					<ui:SymbolIcon Symbol="Eye24" Margin="0,0,6,0"/>
					<TextBlock Text="Preview" VerticalAlignment="Center"/>
				</StackPanel>
			</GroupBox.Header>
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>
				<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,5,5,0">
					<RadioButton x:Name="barcodeRadio" Content="Barcode" VerticalAlignment="Center"
								 IsChecked="True" Margin="5,0" GroupName="PreviewType"
								 Checked="previewTypeChanged"/>
					<RadioButton x:Name="qrCodeRadio" Content="QR Code" VerticalAlignment="Center"
								 Margin="5,0" GroupName="PreviewType"
								 Checked="previewTypeChanged"/>
				</StackPanel>
				<Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Margin="5"
						Background="White">
					<Image x:Name="previewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
				</Border>
			</Grid>
		</GroupBox>
	</Grid>
</UserControl>
