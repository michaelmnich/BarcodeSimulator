<UserControl x:Class="App.Bs.Barcode.Wpf.Ui.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="500">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="15">

            <!-- Theme -->
            <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <GroupBox Header="Theme" Padding="10" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="darkThemeRadio" Content="Dark" GroupName="Theme"
                                 IsChecked="True" Margin="0,0,20,0"
                                 Checked="themeRadio_Checked"/>
                    <RadioButton x:Name="lightThemeRadio" Content="Light" GroupName="Theme"
                                 Checked="themeRadio_Checked"/>
                </StackPanel>
            </GroupBox>

            <!-- Branding -->
            <TextBlock Text="Branding" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,10"/>

            <GroupBox Header="Logo (Dark Theme)" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <Image x:Name="logoDarkImage" MaxHeight="100" Stretch="Uniform"
                           HorizontalAlignment="Left" Margin="0,5,0,0"/>
                    <TextBlock x:Name="logoDarkPath" FontSize="10" Foreground="Gray" Margin="0,5,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Logo (Light Theme)" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <Image x:Name="logoLightImage" MaxHeight="100" Stretch="Uniform"
                           HorizontalAlignment="Left" Margin="0,5,0,0"/>
                    <TextBlock x:Name="logoLightPath" FontSize="10" Foreground="Gray" Margin="0,5,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="QR Icon" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <Image x:Name="qrIconImage" MaxHeight="80" Stretch="Uniform"
                           HorizontalAlignment="Left" Margin="0,5,0,0"/>
                    <TextBlock x:Name="qrIconPath" FontSize="10" Foreground="Gray" Margin="0,5,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
