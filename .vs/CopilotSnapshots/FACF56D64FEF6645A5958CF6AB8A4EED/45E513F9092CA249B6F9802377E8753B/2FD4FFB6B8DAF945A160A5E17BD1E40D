using System;
using System.Collections.ObjectModel;
using System.Diagnostics;
using System.Linq;
using System.Threading;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;
using System.Windows.Interop;
using App.Bs.Barcode;

namespace App.Bs.Barcode.Wpf.Ui
{
    public class BarcodeItem
    {
        public string Code { get; set; } = string.Empty;
        public string TypeName { get; set; } = string.Empty;
    }

    public partial class BarcodeSimulatorControl : UserControl
    {
        private readonly ObservableCollection<BarcodeItem> _items = new();
        private int _currentIndex;

        public BarcodeSimulatorControl()
        {
            InitializeComponent();
            itemsListView.ItemsSource = _items;

            Loaded += BarcodeSimulatorControl_Loaded;
        }

        private void BarcodeSimulatorControl_Loaded(object sender, RoutedEventArgs e)
        {
            // Populate the ends-with combo with common key names
            endsWithComboBox.Items.Add("(None)");
            foreach (var name in Enum.GetNames(typeof(Key)))
            {
                endsWithComboBox.Items.Add(name);
            }
            endsWithComboBox.SelectedIndex = 0;

            hotkeyTextBox.Text = "Windows+Z (use WinForms Hotkey class to register)";

            newStringTextBox.Focus();
        }

        private void newStringTextBox_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.Key != Key.Enter)
                return;

            AddCurrentBarcode();
        }

        private void addButton_Click(object sender, RoutedEventArgs e)
        {
            AddCurrentBarcode();
            newStringTextBox.Focus();
        }

        private void AddCurrentBarcode()
        {
            var code = newStringTextBox.Text;
            if (string.IsNullOrEmpty(code))
                return;

            _items.Add(new BarcodeItem
            {
                Code = code,
                TypeName = Barcode.GetTypeName(code)
            });

            newStringTextBox.Clear();
        }

        private void itemsListView_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.Key != Key.Delete)
                return;

            if (itemsListView.SelectedItem is BarcodeItem selected)
            {
                _items.Remove(selected);
            }
        }

        private void newStringTextBox_TextChanged(object sender, TextChangedEventArgs e)
        {
            var text = newStringTextBox.Text;

            if (string.IsNullOrEmpty(text))
            {
                newCodeTypeLabel.Content = null;
                return;
            }

            var type = Barcode.GetTypeName(text);

            if (newCodeTypeLabel.Content?.ToString() == type)
                return;

            newCodeTypeLabel.Content = type;
        }

        /// <summary>
        /// Gets the next barcode from the list in round-robin order.
        /// Call this from a hotkey handler to retrieve and send the next code.
        /// </summary>
        public string? GetNextCode()
        {
            if (_items.Count == 0)
                return null;

            if (_currentIndex >= _items.Count)
                _currentIndex = 0;

            var code = _items[_currentIndex].Code;
            _currentIndex = (_currentIndex + 1) % _items.Count;

            itemsListView.SelectedIndex = _currentIndex;

            return code;
        }
    }
}
