<UserControl x:Class="App.Bs.Barcode.Wpf.Ui.BarcodeSimulatorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:tt="clr-namespace:App.Bs.Barcode.Wpf.Ui"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="500">
	<Grid Margin="10" d:Background="pink">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- Hotkey -->
		<Label Grid.Row="0" Grid.Column="0" Content="Hotkey:" VerticalAlignment="Center"
               ToolTip="{x:Static tt:ToolTips.Hotkey}"/>
		<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="5"
                    ToolTip="{x:Static tt:ToolTips.Hotkey}">
			<CheckBox x:Name="ctrlCheckBox" Content="Ctrl" VerticalAlignment="Center" IsChecked="True" Margin="0,0,8,0"/>
			<CheckBox x:Name="altCheckBox" Content="Alt" VerticalAlignment="Center" Margin="0,0,8,0"/>
			<CheckBox x:Name="shiftCheckBox" Content="Shift" VerticalAlignment="Center" Margin="0,0,8,0"/>
			<CheckBox x:Name="winCheckBox" Content="Win" VerticalAlignment="Center"  Margin="0,0,8,0"/>
			<Label Content="+" VerticalAlignment="Center" Padding="2"/>
			<TextBox x:Name="hotkeyKeyTextBox" Width="60" VerticalAlignment="Center" Text="\"
                     MaxLength="10" ToolTip="Type the key, e.g. F, D, F1, \"/>
			<Button Content="Register" Margin="8,0,0,0" Padding="8,2" VerticalAlignment="Center"
                    Click="registerHotkeyButton_Click" ToolTip="Click to register or re-register the hotkey."/>
		</StackPanel>

		<!-- Delay -->
		<Label Grid.Row="1" Grid.Column="0" Content="Delay (ms):" VerticalAlignment="Center"
               ToolTip="{x:Static tt:ToolTips.Delay}"/>
		<TextBox x:Name="delayTextBox" Grid.Row="1" Grid.Column="1" Text="50" Margin="5"
                 ToolTip="{x:Static tt:ToolTips.Delay}"/>

		<!-- Ends With -->
		<Label Grid.Row="2" Grid.Column="0" Content="Ends with:" VerticalAlignment="Center"
               ToolTip="{x:Static tt:ToolTips.EndsWith}"/>
		<ComboBox x:Name="endsWithComboBox" Grid.Row="2" Grid.Column="1" Margin="5"
                  ToolTip="{x:Static tt:ToolTips.EndsWith}"/>

		<!-- Items List -->
		<ListView x:Name="itemsListView" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="5"
                  KeyDown="itemsListView_KeyDown"
                  ToolTip="{x:Static tt:ToolTips.ItemsList}">
			<ListView.View>
				<GridView>
					<GridViewColumn Header="Code" DisplayMemberBinding="{Binding Code}" Width="300"/>
					<GridViewColumn Header="Type" DisplayMemberBinding="{Binding TypeName}" Width="100"/>
				</GridView>
			</ListView.View>
		</ListView>

		<!-- New String Entry -->
		<Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<TextBox x:Name="newStringTextBox" Grid.Column="0" Margin="5"
					 MinHeight="60" MaxHeight="120"
					 AcceptsReturn="True" AcceptsTab="True"
					 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
					 TextWrapping="Wrap"
					 FontFamily="Consolas" FontSize="12"
					 TextChanged="newStringTextBox_TextChanged"
					 ToolTip="{x:Static tt:ToolTips.NewString}"/>
			<StackPanel Grid.Column="1" Orientation="Vertical" Margin="5,5,5,5">
				<Button Content="Add" Padding="10,2" Click="addButton_Click" HorizontalAlignment="Center" />
			</StackPanel>
			<Label x:Name="newCodeTypeLabel" Grid.Column="2" VerticalAlignment="Top" MinWidth="60" Margin="0,5,0,0"/>
		</Grid>

		<!-- Preview -->
		<Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" MinHeight="200">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>
			<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,5,5,0">
				<Label Content="Preview:" VerticalAlignment="Center"/>
				<RadioButton x:Name="barcodeRadio" Content="Barcode" VerticalAlignment="Center"
							 IsChecked="True" Margin="5,0" GroupName="PreviewType"
							 Checked="previewTypeChanged"/>
				<RadioButton x:Name="qrCodeRadio" Content="QR Code" VerticalAlignment="Center"
							 Margin="5,0" GroupName="PreviewType"
							 Checked="previewTypeChanged"/>
			</StackPanel>
			<Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Margin="5"
					Background="White">
				<Image x:Name="previewImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
			</Border>
		</Grid>
	</Grid>
</UserControl>
