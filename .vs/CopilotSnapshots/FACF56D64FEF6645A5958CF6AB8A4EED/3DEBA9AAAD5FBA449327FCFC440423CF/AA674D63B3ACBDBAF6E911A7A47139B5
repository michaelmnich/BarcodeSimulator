namespace App.Bs.Barcode.Wpf.Ui
{
    public class BarcodeItem
    {
        public string Code { get; set; } = string.Empty;
        public string TypeName { get; set; } = string.Empty;
    }

    public partial class BarcodeSimulatorControl : UserControl
    {
        private readonly ObservableCollection<BarcodeItem> _items = new();
        private int _currentIndex;

        [DllImport("user32.dll")]
        private static extern IntPtr GetForegroundWindow();

        [DllImport("user32.dll")]
        private static extern bool SetForegroundWindow(IntPtr hWnd);

        private Hotkey? _hotkey;
        private HotkeyMessageControl? _hiddenControl;
        private IntPtr _lastExternalWindow;
        private IntPtr _ourWindowHandle;

        public BarcodeSimulatorControl()
        {
            InitializeComponent();
            itemsListView.ItemsSource = _items;

            Loaded += BarcodeSimulatorControl_Loaded;
            Unloaded += BarcodeSimulatorControl_Unloaded;
        }

        private void BarcodeSimulatorControl_Loaded(object sender, RoutedEventArgs e)
        {
            // Populate the ends-with combo with common key names
            endsWithComboBox.Items.Add("(None)");
            foreach (var name in Enum.GetNames(typeof(Key)))
            {
                endsWithComboBox.Items.Add(name);
            }
            endsWithComboBox.SelectedIndex = 0;

            // Get our window handle for tracking external windows
            var window = Window.GetWindow(this);
            if (window is not null)
            {
                _ourWindowHandle = new WindowInteropHelper(window).EnsureHandle();
            }

            // Create a hidden WinForms control that captures WM_HOTKEY messages
            _hiddenControl = new HotkeyMessageControl();
            _hiddenControl.CreateControl();
            _hiddenControl.HotkeyMessageReceived += msg =>
            {
                // Manually forward to the Hotkey's PreFilterMessage since 
                // WPF does not run the WinForms message pump
                if (_hotkey is not null)
                {
                    var m = msg;
                    _hotkey.PreFilterMessage(ref m);
                }
            };

            // Track the last external foreground window
            var timer = new System.Windows.Threading.DispatcherTimer
            {
                Interval = TimeSpan.FromMilliseconds(250)
            };
            timer.Tick += (_, _) =>
            {
                var fg = GetForegroundWindow();
                if (fg != IntPtr.Zero && fg != _ourWindowHandle)
                {
                    _lastExternalWindow = fg;
                }
            };
            timer.Start();

            RegisterCurrentHotkey();
            newStringTextBox.Focus();
        }

        private void BarcodeSimulatorControl_Unloaded(object sender, RoutedEventArgs e)
        {
            UnregisterCurrentHotkey();
            _hiddenControl?.Dispose();
        }

        /// <summary>
        /// Returns a display string for the currently configured hotkey combination.
        /// </summary>
        public string GetHotkeyDisplayString()
        {
            var parts = new System.Collections.Generic.List<string>();
            if (ctrlCheckBox.IsChecked == true) parts.Add("Ctrl");
            if (altCheckBox.IsChecked == true) parts.Add("Alt");
            if (shiftCheckBox.IsChecked == true) parts.Add("Shift");
            if (winCheckBox.IsChecked == true) parts.Add("Win");

            var key = hotkeyKeyTextBox.Text.Trim();
            if (!string.IsNullOrEmpty(key)) parts.Add(key.ToUpperInvariant());

            return parts.Count > 0 ? string.Join("+", parts) : "(none)";
        }

        private void RegisterCurrentHotkey()
        {
            UnregisterCurrentHotkey();

            if (_hiddenControl is null)
            {
                Debug.WriteLine("[Hotkey] Cannot register: no hidden control");
                return;
            }

            var keyText = hotkeyKeyTextBox.Text.Trim();
            if (string.IsNullOrEmpty(keyText))
            {
                Debug.WriteLine("[Hotkey] Cannot register: empty key text");
                return;
            }

            // Resolve the key to a WinForms Keys value
            var formsKey = ResolveFormsKey(keyText);
            if (formsKey == System.Windows.Forms.Keys.None)
            {
                MessageBox.Show($"Unknown key: '{keyText}'", "Hotkey Error", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            _hotkey = new Hotkey(
                formsKey,
                shift: shiftCheckBox.IsChecked == true,
                control: ctrlCheckBox.IsChecked == true,
                alt: altCheckBox.IsChecked == true,
                windows: winCheckBox.IsChecked == true);

            _hotkey.Pressed += HotkeyPressed;

            try
            {
                if (_hotkey.Register(_hiddenControl))
                {
                    Debug.WriteLine($"[Hotkey] Registered: {_hotkey}");
                }
                else
                {
                    MessageBox.Show($"Failed to register hotkey {GetHotkeyDisplayString()}. It may already be in use.",
                        "Hotkey Error", MessageBoxButton.OK, MessageBoxImage.Warning);
                    _hotkey = null;
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Failed to register hotkey: {ex.Message}",
                    "Hotkey Error", MessageBoxButton.OK, MessageBoxImage.Warning);
                _hotkey = null;
            }
        }

        private void UnregisterCurrentHotkey()
        {
            if (_hotkey is { Registered: true })
            {
                _hotkey.Pressed -= HotkeyPressed;
                _hotkey.Unregister();
                Debug.WriteLine("[Hotkey] Unregistered");
            }
            _hotkey = null;
        }

        private static System.Windows.Forms.Keys ResolveFormsKey(string keyText)
        {
            // Try parsing as a named key (F1, Enter, Tab, etc.)
            if (Enum.TryParse<System.Windows.Forms.Keys>(keyText, ignoreCase: true, out var namedKey))
                return namedKey;

            // Single character — map to Keys enum
            if (keyText.Length == 1)
            {
                char c = char.ToUpperInvariant(keyText[0]);

                // Letters A-Z
                if (c >= 'A' && c <= 'Z')
                    return (System.Windows.Forms.Keys)c;

                // Digits 0-9
                if (c >= '0' && c <= '9')
                    return (System.Windows.Forms.Keys)c;

                // Special characters — map via VkKeyScan
                short vk = VkKeyScan(keyText[0]);
                if (vk != -1)
                    return (System.Windows.Forms.Keys)(vk & 0xFF);
            }

            return System.Windows.Forms.Keys.None;
        }

        [DllImport("user32.dll")]
        private static extern short VkKeyScan(char ch);

        private void HotkeyPressed(object? sender, HandledEventArgs e)
        {
            e.Handled = true;
            Debug.WriteLine($"[Hotkey] Pressed! Target window: 0x{_lastExternalWindow:X}");

            if (_items.Count == 0)
            {
                MessageBox.Show("You have to add some strings to the list first.", "Fail",
                    MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            var code = GetNextCode();
            if (code is null) return;

            int delay = int.TryParse(delayTextBox.Text, out var d) ? d : 50;

            Key endKey = Key.None;
            if (endsWithComboBox.SelectedIndex > 0)
                Enum.TryParse(endsWithComboBox.SelectedItem?.ToString(), out endKey);

            var targetWindow = _lastExternalWindow;

            // Send keys on a background thread so we don't block the UI
            var thread = new Thread(() => StartSending(code, delay, endKey, targetWindow))
            {
                Name = "Sending keys " + code
            };
            thread.Start();
        }

        private static void StartSending(string text, int delay, Key endKey, IntPtr targetWindow)
        {
            // Restore focus to the window that was active before
            if (targetWindow != IntPtr.Zero)
            {
                SetForegroundWindow(targetWindow);
                Thread.Sleep(100);
            }

            foreach (var ch in text)
            {
                Debug.WriteLine("{0} Sending text '{1}'", DateTime.Now.ToString("HH:mm:ss.fff"), ch);
                System.Windows.Forms.SendKeys.SendWait(ch.ToString());
                System.Windows.Forms.SendKeys.Flush();
                Thread.Sleep(delay);
            }

            if (endKey != Key.None)
            {
                var sendKeysName = MapKeyToSendKeysName(endKey);
                if (sendKeysName is not null)
                {
                    System.Windows.Forms.SendKeys.SendWait(sendKeysName);
                }
            }

            System.Media.SystemSounds.Beep.Play();
        }

        private static string? MapKeyToSendKeysName(Key key) => key switch
        {
            Key.Enter => "{ENTER}",
            Key.Tab => "{TAB}",
            Key.Escape => "{ESC}",
            Key.Back => "{BACKSPACE}",
            Key.Delete => "{DELETE}",
            Key.Insert => "{INSERT}",
            Key.Home => "{HOME}",
            Key.End => "{END}",
            Key.PageUp => "{PGUP}",
            Key.PageDown => "{PGDN}",
            Key.Up => "{UP}",
            Key.Down => "{DOWN}",
            Key.Left => "{LEFT}",
            Key.Right => "{RIGHT}",
            Key.CapsLock => "{CAPSLOCK}",
            Key.PrintScreen => "{PRTSC}",
            Key.Scroll => "{SCROLLLOCK}",
            Key.NumLock => "{NUMLOCK}",
            Key.F1 => "{F1}",
            Key.F2 => "{F2}",
            Key.F3 => "{F3}",
            Key.F4 => "{F4}",
            Key.F5 => "{F5}",
            Key.F6 => "{F6}",
            Key.F7 => "{F7}",
            Key.F8 => "{F8}",
            Key.F9 => "{F9}",
            Key.F10 => "{F10}",
            Key.F11 => "{F11}",
            Key.F12 => "{F12}",
            Key.Space => " ",
            _ => null
        };

        private void newStringTextBox_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.Key != Key.Enter)
                return;

            AddCurrentBarcode();
        }

        private void registerHotkeyButton_Click(object sender, RoutedEventArgs e)
        {
            RegisterCurrentHotkey();
        }

        private void addButton_Click(object sender, RoutedEventArgs e)
        {
            AddCurrentBarcode();
            newStringTextBox.Focus();
        }

        private void AddCurrentBarcode()
        {
            var code = newStringTextBox.Text;
            if (string.IsNullOrEmpty(code))
                return;

            _items.Add(new BarcodeItem
            {
                Code = code,
                TypeName = Barcode.GetTypeName(code)
            });

            newStringTextBox.Clear();
        }

        private void itemsListView_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.Key != Key.Delete)
                return;

            if (itemsListView.SelectedItem is BarcodeItem selected)
            {
                _items.Remove(selected);
            }
        }

        private void newStringTextBox_TextChanged(object sender, TextChangedEventArgs e)
        {
            var text = newStringTextBox.Text;

            if (string.IsNullOrEmpty(text))
            {
                newCodeTypeLabel.Content = null;
                return;
            }

            var type = Barcode.GetTypeName(text);

            if (newCodeTypeLabel.Content?.ToString() == type)
                return;

            newCodeTypeLabel.Content = type;
        }

        public string? GetNextCode()
        {
            if (_items.Count == 0)
                return null;

            if (_currentIndex >= _items.Count)
                _currentIndex = 0;

            var code = _items[_currentIndex].Code;
            _currentIndex = (_currentIndex + 1) % _items.Count;

            itemsListView.SelectedIndex = _currentIndex;

            return code;
        }
    }
}
