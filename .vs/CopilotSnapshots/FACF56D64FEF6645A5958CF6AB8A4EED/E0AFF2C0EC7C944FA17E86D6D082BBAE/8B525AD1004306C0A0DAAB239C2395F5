using System;
using System.Collections.ObjectModel;
using System.ComponentModel;
using System.Diagnostics;
using System.Linq;
using System.Runtime.InteropServices;
using System.Threading;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Input;
using System.Windows.Interop;
using App.Bs.Barcode;
using MessageBox = System.Windows.MessageBox;
using UserControl = System.Windows.Controls.UserControl;
using KeyEventArgs = System.Windows.Input.KeyEventArgs;

namespace App.Bs.Barcode.Wpf.Ui
{
    public class BarcodeItem
    {
        public string Code { get; set; } = string.Empty;
        public string TypeName { get; set; } = string.Empty;
    }

    public partial class BarcodeSimulatorControl : UserControl
    {
        private readonly ObservableCollection<BarcodeItem> _items = new();
        private int _currentIndex;

        private const int WM_HOTKEY = 0x0312;
        private const int HOTKEY_ID = 9000;

        private const uint MOD_ALT = 0x1;
        private const uint MOD_CONTROL = 0x2;
        private const uint MOD_SHIFT = 0x4;
        private const uint MOD_WIN = 0x8;
        private const uint MOD_NOREPEAT = 0x4000;

        [DllImport("user32.dll", SetLastError = true)]
        private static extern bool RegisterHotKey(IntPtr hWnd, int id, uint fsModifiers, uint vk);

        [DllImport("user32.dll", SetLastError = true)]
        private static extern bool UnregisterHotKey(IntPtr hWnd, int id);

        [DllImport("user32.dll")]
        private static extern short VkKeyScan(char ch);

        [DllImport("user32.dll")]
        private static extern IntPtr GetForegroundWindow();

        [DllImport("user32.dll")]
        private static extern bool SetForegroundWindow(IntPtr hWnd);

        private HwndSource? _hwndSource;
        private bool _hotkeyRegistered;

        public BarcodeSimulatorControl()
        {
            InitializeComponent();
            itemsListView.ItemsSource = _items;

            Loaded += BarcodeSimulatorControl_Loaded;
            Unloaded += BarcodeSimulatorControl_Unloaded;
        }

        private void BarcodeSimulatorControl_Loaded(object sender, RoutedEventArgs e)
        {
            // Populate the ends-with combo with common key names
            endsWithComboBox.Items.Add("(None)");
            foreach (var name in Enum.GetNames(typeof(Key)))
            {
                endsWithComboBox.Items.Add(name);
            }
            endsWithComboBox.SelectedIndex = 0;

            // Hook into the window's message loop
            var window = Window.GetWindow(this);
            if (window is not null)
            {
                var helper = new WindowInteropHelper(window);
                var hwnd = helper.EnsureHandle();
                _hwndSource = HwndSource.FromHwnd(hwnd);
                _hwndSource?.AddHook(WndProc);
                Debug.WriteLine($"[Hotkey] HwndSource hooked, handle=0x{hwnd:X}");
            }
            else
            {
                Debug.WriteLine("[Hotkey] ERROR: Window.GetWindow returned null");
            }

            RegisterCurrentHotkey();
            newStringTextBox.Focus();
        }

        private void BarcodeSimulatorControl_Unloaded(object sender, RoutedEventArgs e)
        {
            UnregisterCurrentHotkey();
            _hwndSource?.RemoveHook(WndProc);
        }

        /// <summary>
        /// Returns a display string for the currently configured hotkey combination.
        /// </summary>
        public string GetHotkeyDisplayString()
        {
            var parts = new System.Collections.Generic.List<string>();
            if (ctrlCheckBox.IsChecked == true) parts.Add("Ctrl");
            if (altCheckBox.IsChecked == true) parts.Add("Alt");
            if (shiftCheckBox.IsChecked == true) parts.Add("Shift");
            if (winCheckBox.IsChecked == true) parts.Add("Win");

            var key = hotkeyKeyTextBox.Text.Trim();
            if (!string.IsNullOrEmpty(key)) parts.Add(key.ToUpperInvariant());

            return parts.Count > 0 ? string.Join("+", parts) : "(none)";
        }

        private void RegisterCurrentHotkey()
        {
            UnregisterCurrentHotkey();

            if (_hwndSource is null)
            {
                Debug.WriteLine("[Hotkey] Cannot register: no HwndSource");
                return;
            }

            var keyText = hotkeyKeyTextBox.Text.Trim();
            if (string.IsNullOrEmpty(keyText))
            {
                Debug.WriteLine("[Hotkey] Cannot register: empty key text");
                return;
            }

            uint vk = ResolveVirtualKey(keyText);
            Debug.WriteLine($"[Hotkey] ResolveVirtualKey('{keyText}') = 0x{vk:X2}");
            if (vk == 0)
            {
                MessageBox.Show($"Unknown key: '{keyText}'", "Hotkey Error", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            uint modifiers = MOD_NOREPEAT;
            if (ctrlCheckBox.IsChecked == true) modifiers |= MOD_CONTROL;
            if (altCheckBox.IsChecked == true) modifiers |= MOD_ALT;
            if (shiftCheckBox.IsChecked == true) modifiers |= MOD_SHIFT;
            if (winCheckBox.IsChecked == true) modifiers |= MOD_WIN;

            bool result = RegisterHotKey(_hwndSource.Handle, HOTKEY_ID, modifiers, vk);
            int error = result ? 0 : Marshal.GetLastWin32Error();
            Debug.WriteLine($"[Hotkey] RegisterHotKey(modifiers=0x{modifiers:X}, vk=0x{vk:X2}) => {result}, error={error}");

            if (result)
            {
                _hotkeyRegistered = true;
                Debug.WriteLine($"[Hotkey] Registered: {GetHotkeyDisplayString()}");
            }
            else
            {
                MessageBox.Show($"Failed to register hotkey {GetHotkeyDisplayString()}.\nError code: {error}\nIt may already be in use.",
                    "Hotkey Error", MessageBoxButton.OK, MessageBoxImage.Warning);
            }
        }

        private void UnregisterCurrentHotkey()
        {
            if (_hotkeyRegistered && _hwndSource is not null)
            {
                UnregisterHotKey(_hwndSource.Handle, HOTKEY_ID);
                _hotkeyRegistered = false;
            }
        }

        private static uint ResolveVirtualKey(string keyText)
        {
            // Single character — use VkKeyScan first (handles \, /, letters, digits, etc.)
            if (keyText.Length == 1)
            {
                short result = VkKeyScan(keyText[0]);
                if (result != -1)
                {
                    uint vk = (uint)(result & 0xFF);
                    Debug.WriteLine($"[Hotkey] VkKeyScan('{keyText[0]}') = 0x{vk:X2}");
                    return vk;
                }
            }

            // Try well-known names (F1-F24, Enter, Tab, etc.)
            if (Enum.TryParse<System.Windows.Forms.Keys>(keyText, ignoreCase: true, out var fk))
                return (uint)fk;

            return 0;
        }

        private IntPtr WndProc(IntPtr hwnd, int msg, IntPtr wParam, IntPtr lParam, ref bool handled)
        {
            if (msg == WM_HOTKEY && wParam.ToInt32() == HOTKEY_ID)
            {
                handled = true;
                // Capture which window had focus BEFORE we do anything
                var foregroundWindow = GetForegroundWindow();
                OnHotkeyPressed(foregroundWindow);
            }
            return IntPtr.Zero;
        }

        private void OnHotkeyPressed(IntPtr targetWindow)
        {
            if (_items.Count == 0)
            {
                MessageBox.Show("You have to add some strings to the list first.", "Fail",
                    MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            var code = GetNextCode();
            if (code is null) return;

            int delay = int.TryParse(delayTextBox.Text, out var d) ? d : 50;

            Key endKey = Key.None;
            if (endsWithComboBox.SelectedIndex > 0)
                Enum.TryParse(endsWithComboBox.SelectedItem?.ToString(), out endKey);

            // Send keys on a background thread so we don't block the UI
            var thread = new Thread(() => StartSending(code, delay, endKey, targetWindow))
            {
                Name = "Sending keys " + code
            };
            thread.Start();
        }

        private static void StartSending(string text, int delay, Key endKey, IntPtr targetWindow)
        {
            // Restore focus to the window that was active when the hotkey was pressed
            if (targetWindow != IntPtr.Zero)
            {
                SetForegroundWindow(targetWindow);
                Thread.Sleep(100); // small delay to let the target window activate
            }
            foreach (var ch in text)
            {
                Debug.WriteLine("{0} Sending text '{1}'", DateTime.Now.ToString("HH:mm:ss.fff"), ch);
                System.Windows.Forms.SendKeys.SendWait(ch.ToString());
                System.Windows.Forms.SendKeys.Flush();
                Thread.Sleep(delay);
            }

            if (endKey != Key.None)
            {
                // Map WPF Key to SendKeys format
                var sendKeysName = MapKeyToSendKeysName(endKey);
                if (sendKeysName is not null)
                {
                    System.Windows.Forms.SendKeys.SendWait(sendKeysName);
                }
            }

            System.Media.SystemSounds.Beep.Play();
        }

        /// <summary>
        /// Maps a WPF Key to the SendKeys format string.
        /// SendKeys uses specific names like {ENTER}, {TAB}, {ESC}, etc.
        /// See: https://learn.microsoft.com/dotnet/api/system.windows.forms.sendkeys
        /// </summary>
        private static string? MapKeyToSendKeysName(Key key) => key switch
        {
            Key.Enter => "{ENTER}",
            Key.Tab => "{TAB}",
            Key.Escape => "{ESC}",
            Key.Back => "{BACKSPACE}",
            Key.Delete => "{DELETE}",
            Key.Insert => "{INSERT}",
            Key.Home => "{HOME}",
            Key.End => "{END}",
            Key.PageUp => "{PGUP}",
            Key.PageDown => "{PGDN}",
            Key.Up => "{UP}",
            Key.Down => "{DOWN}",
            Key.Left => "{LEFT}",
            Key.Right => "{RIGHT}",
            Key.CapsLock => "{CAPSLOCK}",
            Key.PrintScreen => "{PRTSC}",
            Key.Scroll => "{SCROLLLOCK}",
            Key.NumLock => "{NUMLOCK}",
            Key.F1 => "{F1}",
            Key.F2 => "{F2}",
            Key.F3 => "{F3}",
            Key.F4 => "{F4}",
            Key.F5 => "{F5}",
            Key.F6 => "{F6}",
            Key.F7 => "{F7}",
            Key.F8 => "{F8}",
            Key.F9 => "{F9}",
            Key.F10 => "{F10}",
            Key.F11 => "{F11}",
            Key.F12 => "{F12}",
            Key.Space => " ",
            _ => null
        };

        private void newStringTextBox_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.Key != Key.Enter)
                return;

            AddCurrentBarcode();
        }

        private void registerHotkeyButton_Click(object sender, RoutedEventArgs e)
        {
            RegisterCurrentHotkey();
        }

        private void addButton_Click(object sender, RoutedEventArgs e)
        {
            AddCurrentBarcode();
            newStringTextBox.Focus();
        }

        private void AddCurrentBarcode()
        {
            var code = newStringTextBox.Text;
            if (string.IsNullOrEmpty(code))
                return;

            _items.Add(new BarcodeItem
            {
                Code = code,
                TypeName = Barcode.GetTypeName(code)
            });

            newStringTextBox.Clear();
        }

        private void itemsListView_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.Key != Key.Delete)
                return;

            if (itemsListView.SelectedItem is BarcodeItem selected)
            {
                _items.Remove(selected);
            }
        }

        private void newStringTextBox_TextChanged(object sender, TextChangedEventArgs e)
        {
            var text = newStringTextBox.Text;

            if (string.IsNullOrEmpty(text))
            {
                newCodeTypeLabel.Content = null;
                return;
            }

            var type = Barcode.GetTypeName(text);

            if (newCodeTypeLabel.Content?.ToString() == type)
                return;

            newCodeTypeLabel.Content = type;
        }

        /// <summary>
        /// Gets the next barcode from the list in round-robin order.
        /// Call this from a hotkey handler to retrieve and send the next code.
        /// </summary>
        public string? GetNextCode()
        {
            if (_items.Count == 0)
                return null;

            if (_currentIndex >= _items.Count)
                _currentIndex = 0;

            var code = _items[_currentIndex].Code;
            _currentIndex = (_currentIndex + 1) % _items.Count;

            itemsListView.SelectedIndex = _currentIndex;

            return code;
        }
    }
}
