<UserControl x:Class="App.Bs.Barcode.Wpf.Ui.BarcodeSimulatorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:tt="clr-namespace:App.Bs.Barcode.Wpf.Ui"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Hotkey -->
        <Label Grid.Row="0" Grid.Column="0" Content="Hotkey:" VerticalAlignment="Center"
               ToolTip="{x:Static tt:ToolTips.Hotkey}"/>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="5"
                    ToolTip="{x:Static tt:ToolTips.Hotkey}">
            <CheckBox x:Name="ctrlCheckBox" Content="Ctrl" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <CheckBox x:Name="altCheckBox" Content="Alt" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <CheckBox x:Name="shiftCheckBox" Content="Shift" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <CheckBox x:Name="winCheckBox" Content="Win" VerticalAlignment="Center" IsChecked="True" Margin="0,0,8,0"/>
            <Label Content="+" VerticalAlignment="Center" Padding="2"/>
            <TextBox x:Name="hotkeyKeyTextBox" Width="60" VerticalAlignment="Center" Text="Z"
                     MaxLength="10" ToolTip="Type the key, e.g. F, D, F1, \"/>
        </StackPanel>

        <!-- Delay -->
        <Label Grid.Row="1" Grid.Column="0" Content="Delay (ms):" VerticalAlignment="Center"
               ToolTip="{x:Static tt:ToolTips.Delay}"/>
        <TextBox x:Name="delayTextBox" Grid.Row="1" Grid.Column="1" Text="50" Margin="5"
                 ToolTip="{x:Static tt:ToolTips.Delay}"/>

        <!-- Ends With -->
        <Label Grid.Row="2" Grid.Column="0" Content="Ends with:" VerticalAlignment="Center"
               ToolTip="{x:Static tt:ToolTips.EndsWith}"/>
        <ComboBox x:Name="endsWithComboBox" Grid.Row="2" Grid.Column="1" Margin="5"
                  ToolTip="{x:Static tt:ToolTips.EndsWith}"/>

        <!-- Items List -->
        <ListView x:Name="itemsListView" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="5"
                  KeyDown="itemsListView_KeyDown"
                  ToolTip="{x:Static tt:ToolTips.ItemsList}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Code" DisplayMemberBinding="{Binding Code}" Width="300"/>
                    <GridViewColumn Header="Type" DisplayMemberBinding="{Binding TypeName}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- New String Entry -->
        <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="newStringTextBox" Grid.Column="0" Margin="5"
                     KeyDown="newStringTextBox_KeyDown" TextChanged="newStringTextBox_TextChanged"
                     ToolTip="{x:Static tt:ToolTips.NewString}"/>
            <Button Content="Add" Grid.Column="1" Margin="5" Padding="10,2"
                    Click="addButton_Click"/>
            <Label x:Name="newCodeTypeLabel" Grid.Column="2" VerticalAlignment="Center" MinWidth="60"/>
        </Grid>
    </Grid>
</UserControl>
